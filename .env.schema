# Environment for the Astro vault template.
# Copy to .env and fill in values; .env is gitignored.

# Path to the Obsidian vault (relative to repo root).
OBSIDIAN_VAULT_DIR=content

# Site identity
SITE_URL=https://example.com
SITE_TITLE=My Vault
SITE_DESCRIPTION=Notes published with the Astro vault template.

# Accent hue for the theme (0–360). Obsidian Publish's default is 258.
ACCENT_HUE=258
