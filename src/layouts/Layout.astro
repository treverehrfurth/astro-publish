---
import '../styles/base.css';
import '../styles/layout.css';
import '../styles/nav.css';
import '../styles/rail.css';
import '../styles/typography.css';
import '../styles/popover.css';
import '../styles/graph.css';
import '../styles/search.css';

import { ClientRouter } from 'astro:transitions';

import LeftNav from '@/components/LeftNav.astro';
import PreviewPopover from '@/components/PreviewPopover.astro';
import SearchPalette from '@/components/SearchPalette.astro';
import GraphView from '@/components/GraphView.astro';

interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
}

const {
  title = process.env.SITE_TITLE ?? 'My Vault',
  description = process.env.SITE_DESCRIPTION ?? 'A static site published from an Obsidian vault, built with Astro and styled to closely resemble Obsidian Publish.',
  currentSlug = '',
} = Astro.props as Props;

const siteTitle = process.env.SITE_TITLE ?? 'My Vault';
const fullTitle = title === siteTitle ? siteTitle : `${title} · ${siteTitle}`;

// Absolute URLs for social-share previews. `Astro.site` comes from
// astro.config.ts; `Astro.url.pathname` is the current page. Drop a
// `og-image.png` (recommended 1200x630) into `public/` to use it.
const canonicalURL = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImageURL = Astro.site ? new URL('/og-image.png', Astro.site).href : '/og-image.png';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content={siteTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script is:inline>
      // Re-applied on every page load AND every view-transition swap. Astro's
      // ClientRouter preserves `class` on <html> but strips other attributes
      // (including data-theme), so without this the theme would visibly flip
      // when navigating.
      (function () {
        function applyTheme() {
          let t;
          try { t = localStorage.getItem('theme'); } catch {}
          document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark');
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();

      // Apply the saved nav width before first paint so we don't flash
      // the default width and snap to the user's preferred size.
      (function () {
        function applyNavWidth() {
          let stored;
          try { stored = parseInt(localStorage.getItem('nav-width') || '', 10); } catch {}
          if (!Number.isFinite(stored)) return;
          var min = 280;
          var max = Math.min(800, Math.max(min, Math.round(window.innerWidth * 0.5)));
          var w = Math.max(min, Math.min(max, stored));
          document.documentElement.style.setProperty('--nav-width', w + 'px');
        }
        applyNavWidth();
        document.addEventListener('astro:after-swap', applyNavWidth);
      })();
    </script>

    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />

    <ClientRouter />
  </head>
  <body>
    <div class="mobile-topbar" transition:persist="mobile-topbar">
      <button class="topbar-btn topbar-btn-left" type="button" data-mobile-nav-toggle aria-label="Open navigation">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2" />
          <line x1="9" y1="3" x2="9" y2="21" />
        </svg>
      </button>
      <a class="topbar-title" href="/">{siteTitle}</a>
      <button class="topbar-btn topbar-btn-right" type="button" data-mobile-rail-toggle aria-label="Open contents">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none" shape-rendering="crispEdges" aria-hidden="true">
          <rect x="4" y="5" width="16" height="2" rx="1" />
          <rect x="4" y="11" width="13" height="2" rx="1" />
          <rect x="4" y="17" width="10" height="2" rx="1" />
        </svg>
      </button>
    </div>
    <div class="app">
      <LeftNav currentSlug={currentSlug} />
      <main class="app-main">
        <slot />
      </main>
      <slot name="rail" />
    </div>
    <div class="nav-backdrop" data-nav-backdrop aria-hidden="true"></div>
    <PreviewPopover />
    <SearchPalette />
    <GraphView />

    <script is:inline>
      // Theme toggle click handler — guarded so we don't double-attach when
      // this inline script re-executes after a view-transition swap (the
      // toggle button itself is inside the persisted nav, so it stays put).
      (function () {
        if (window.__themeToggleAttached) return;
        window.__themeToggleAttached = true;
        document.addEventListener('click', (ev) => {
          const btn = ev.target.closest && ev.target.closest('[data-theme-toggle]');
          if (!btn) return;
          const cur = document.documentElement.getAttribute('data-theme') || 'dark';
          const next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          try { localStorage.setItem('theme', next); } catch {}
        });
      })();

      // Manually preserve the nav-tree's scrollTop across view transitions.
      // transition:persist on .app-nav keeps the DOM, but native scroll
      // restoration on overflow children isn't always reliable, so we save
      // and restore explicitly.
      // Show platform-appropriate search shortcut hint (Cmd on Mac,
      // Ctrl elsewhere). The handler already accepts both.
      (function () {
        if (window.__searchKbdLabelled) return;
        window.__searchKbdLabelled = true;
        const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform || navigator.userAgent || '');
        const label = isMac ? '⌘K' : 'Ctrl K';
        document.querySelectorAll('[data-search-kbd]').forEach((el) => { el.textContent = label; });
      })();

      (function () {
        if (window.__navScrollGuard) return;
        window.__navScrollGuard = true;
        let savedTop = 0;
        document.addEventListener('astro:before-preparation', () => {
          const tree = document.querySelector('.nav-tree');
          if (tree) savedTop = tree.scrollTop;
        });
        document.addEventListener('astro:after-swap', () => {
          const tree = document.querySelector('.nav-tree');
          if (tree) tree.scrollTop = savedTop;
        });
      })();

      // Drag-to-resize on the nav-resize-handle. Document-level pointerdown
      // delegation so it survives view-transition DOM swaps without
      // re-attaching anything.
      (function () {
        if (window.__navResizeAttached) return;
        window.__navResizeAttached = true;

        const KEY = 'nav-width';
        const MIN = 280;
        function maxFor(vw) {
          return Math.min(800, Math.max(MIN, Math.round(vw * 0.5)));
        }

        document.addEventListener('pointerdown', (e) => {
          const t = e.target;
          if (!t || !t.closest) return;
          const handle = t.closest('[data-nav-resize]');
          if (!handle) return;
          // Mobile breakpoint hides the handle via display:none, but
          // belt-and-suspenders: skip if nav is in slide-out mode.
          if (window.matchMedia('(max-width: 720px)').matches) return;
          e.preventDefault();
          try { handle.setPointerCapture(e.pointerId); } catch {}
          handle.classList.add('is-dragging');
          document.body.classList.add('is-nav-resizing');

          const onMove = (ev) => {
            const max = maxFor(window.innerWidth);
            const w = Math.max(MIN, Math.min(max, ev.clientX));
            document.documentElement.style.setProperty('--nav-width', w + 'px');
          };
          const onUp = (ev) => {
            handle.removeEventListener('pointermove', onMove);
            handle.removeEventListener('pointerup', onUp);
            handle.removeEventListener('pointercancel', onUp);
            handle.classList.remove('is-dragging');
            document.body.classList.remove('is-nav-resizing');
            const max = maxFor(window.innerWidth);
            const w = Math.max(MIN, Math.min(max, ev.clientX));
            try { localStorage.setItem(KEY, String(Math.round(w))); } catch {}
          };
          handle.addEventListener('pointermove', onMove);
          handle.addEventListener('pointerup', onUp);
          handle.addEventListener('pointercancel', onUp);
        });

        // If the viewport shrinks, clamp the stored width so the nav
        // doesn't overflow into where the article should be.
        window.addEventListener('resize', () => {
          const cur = getComputedStyle(document.documentElement).getPropertyValue('--nav-width').trim();
          const px = parseInt(cur, 10);
          if (!Number.isFinite(px)) return;
          const max = maxFor(window.innerWidth);
          if (px > max) {
            document.documentElement.style.setProperty('--nav-width', max + 'px');
          }
        });
      })();
    </script>
  </body>
</html>
