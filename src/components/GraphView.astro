---
// Renders a force-directed graph in the right rail (mode="local") or in a modal.
// In a modal, mode can be "local" (expanded view of the current note's neighborhood)
// or "global" (the entire vault graph). Loaded as a deferred client island so it
// doesn't block first paint.
//
// Node colors come from `siteConfig.graphColors` — emitted here as a JSON
// blob so the client-side script can pick it up without bundling the
// config module.
import { siteConfig } from '@/config/site';
const graphColorsJson = JSON.stringify(siteConfig.graphColors ?? {});
---

<script type="application/json" id="graph-colors-config" set:html={graphColorsJson}></script>

<script>
  import { forceSimulation, forceLink, forceManyBody, forceCenter, forceCollide, forceX, forceY, forceRadial } from 'd3-force';
  import { zoom, zoomIdentity, type ZoomBehavior } from 'd3-zoom';
  import { select, pointer } from 'd3-selection';

  type GraphNode = { id: string; title: string; group?: string; x?: number; y?: number; vx?: number; vy?: number; fx?: number | null; fy?: number | null };
  type GraphEdge = { source: string | GraphNode; target: string | GraphNode };

  type GraphData = { nodes: GraphNode[]; edges: GraphEdge[] };

  let cached: GraphData | null = null;
  async function loadGraph(): Promise<GraphData> {
    if (cached) return cached;
    const r = await fetch('/graph.json');
    cached = (await r.json()) as GraphData;
    return cached;
  }

  // Color map injected from src/config/site.ts via the inline JSON blob
  // above. CSS-var references like `var(--accent)` are resolved at runtime.
  let graphColors: Record<string, string> | null = null;
  function loadGraphColors(): Record<string, string> {
    if (graphColors) return graphColors;
    const node = document.getElementById('graph-colors-config');
    try {
      graphColors = node && node.textContent ? JSON.parse(node.textContent) : {};
    } catch {
      graphColors = {};
    }
    return graphColors!;
  }
  function resolveColor(value: string, fallback: string): string {
    if (!value) return fallback;
    const m = value.match(/^var\((--[a-zA-Z0-9_-]+)\)$/);
    if (m) {
      const v = getComputedStyle(document.documentElement).getPropertyValue(m[1]).trim();
      return v || fallback;
    }
    return value;
  }
  function colorForGroup(group: string | undefined, accent: string, fallback: string): string {
    const colors = loadGraphColors();
    if (group && colors[group]) return resolveColor(colors[group], fallback);
    if (colors.default) return resolveColor(colors.default, fallback);
    return accent || fallback;
  }

  async function renderGraph(host: HTMLElement, mode: 'local' | 'global', centerSlug: string | null) {
    // Clean any prior render in this host (used by the modal swap from local→global).
    host.querySelectorAll('canvas').forEach((c) => c.remove());

    const data = await loadGraph();
    const accent = getCSSVar('--accent') || '#9b6cff';
    const muted = getCSSVar('--text-faint') || '#666';
    const text = getCSSVar('--text-muted') || '#999';
    const edgeColor = getCSSVar('--border') || '#363636';

    let sourceNodes = data.nodes;
    let sourceEdges = data.edges;

    if (mode === 'local' && centerSlug != null) {
      const keep = new Set<string>([centerSlug]);
      for (const e of data.edges) {
        const s = typeof e.source === 'string' ? e.source : e.source.id;
        const t = typeof e.target === 'string' ? e.target : e.target.id;
        if (s === centerSlug) keep.add(t);
        if (t === centerSlug) keep.add(s);
      }
      sourceNodes = data.nodes.filter((n) => keep.has(n.id));
      sourceEdges = data.edges.filter((e) => {
        const s = typeof e.source === 'string' ? e.source : e.source.id;
        const t = typeof e.target === 'string' ? e.target : e.target.id;
        return keep.has(s) && keep.has(t);
      });
    }

    // Clone nodes so this simulation's mutations don't bleed into other
    // simulations sharing the same cached graph data (e.g. opening the
    // modal global graph would otherwise leave stale x/y on every node
    // that the rail-side local sim then inherits when you navigate, and
    // the local layout starts overlapping after a few page clicks).
    const nodes: GraphNode[] = sourceNodes.map((n) => ({ id: n.id, title: n.title, group: n.group }));

    // Map edge source/target strings to node refs (d3-force will mutate to objects)
    const byId = new Map(nodes.map((n) => [n.id, n]));
    const edges = sourceEdges;
    const linkData = edges
      .map((e) => {
        const s = byId.get(typeof e.source === 'string' ? e.source : e.source.id);
        const t = byId.get(typeof e.target === 'string' ? e.target : e.target.id);
        if (!s || !t) return null;
        return { source: s, target: t };
      })
      .filter(Boolean) as Array<{ source: GraphNode; target: GraphNode }>;

    // In local mode, pin the current-page node at the canvas center
    // (Obsidian-style) so the neighborhood orbits around it instead of
    // the center node drifting somewhere off-canvas in the small rail
    // viewport. resize() updates the pin position when the host resizes.
    const centerNode = mode === 'local' && centerSlug
      ? nodes.find((n) => n.id === centerSlug) ?? null
      : null;

    // Radial layout target. Actual seeding of neighbor positions happens
    // inside resize() once we know the canvas dimensions — seeding here
    // (around 0,0) and then translating to canvas center inside resize
    // would let the simulation tick a few times with neighbors far from
    // their final ring positions, which produces clustered layouts.
    const RADIAL_RADIUS = 90;
    let firstSeed = true;

    // Precompute degree per node so we can scale radius by connectivity —
    // hubs render bigger, leaves stay small (Obsidian-style).
    const degree = new Map<string, number>();
    for (const n of nodes) degree.set(n.id, 0);
    for (const e of linkData) {
      const sId = (e.source as GraphNode).id;
      const tId = (e.target as GraphNode).id;
      degree.set(sId, (degree.get(sId) ?? 0) + 1);
      degree.set(tId, (degree.get(tId) ?? 0) + 1);
    }
    function radiusFor(n: GraphNode): number {
      const deg = degree.get(n.id) ?? 0;
      return 3 + Math.min(7, Math.sqrt(deg) * 0.9);
    }

    // Word-wrap each title to at most 2 lines, capped at ~110 screen pixels
    // wide. The wrap is computed once per node against a fixed reference
    // font (the same on-screen size we draw at) and cached, so it doesn't
    // cost anything per frame and is independent of zoom.
    const LABEL_FONT = '400 13px Inter, system-ui, sans-serif';
    const LABEL_MAX_WIDTH = 130;
    const measureCanvas = document.createElement('canvas');
    const measureCtx = measureCanvas.getContext('2d')!;
    measureCtx.font = LABEL_FONT;
    const labelLines = new Map<string, string[]>();
    function wrappedLabel(n: GraphNode): string[] {
      const cached = labelLines.get(n.id);
      if (cached) return cached;
      const lines = wrapTwoLines(n.title, LABEL_MAX_WIDTH);
      labelLines.set(n.id, lines);
      return lines;
    }
    function wrapTwoLines(text: string, maxWidth: number): string[] {
      const words = text.split(/\s+/).filter(Boolean);
      if (words.length <= 1) return [text];
      if (measureCtx.measureText(text).width <= maxWidth) return [text];
      // Find the split that minimizes the longer of the two lines while both fit.
      let bestSplit = -1;
      let bestLonger = Infinity;
      for (let i = 1; i < words.length; i++) {
        const a = words.slice(0, i).join(' ');
        const b = words.slice(i).join(' ');
        const wa = measureCtx.measureText(a).width;
        const wb = measureCtx.measureText(b).width;
        const longer = Math.max(wa, wb);
        if (longer <= maxWidth && longer < bestLonger) {
          bestSplit = i;
          bestLonger = longer;
        }
      }
      if (bestSplit === -1) {
        // No 2-line split fits; pick the split that minimizes overflow so
        // at worst one word pokes past the budget.
        for (let i = 1; i < words.length; i++) {
          const a = words.slice(0, i).join(' ');
          const b = words.slice(i).join(' ');
          const longer = Math.max(measureCtx.measureText(a).width, measureCtx.measureText(b).width);
          if (longer < bestLonger) {
            bestSplit = i;
            bestLonger = longer;
          }
        }
      }
      if (bestSplit === -1) return [text];
      return [words.slice(0, bestSplit).join(' '), words.slice(bestSplit).join(' ')];
    }

    // Label-aware collide radius: each node reserves enough room for the
    // widest of its label lines plus the vertical extent of its (up to 2)
    // lines. Without this the simulation packs nodes tight enough that
    // labels overlap badly even though the circles don't.
    const collideCache = new Map<string, number>();
    function collideRadius(n: GraphNode): number {
      const cached = collideCache.get(n.id);
      if (cached !== undefined) return cached;
      const r = radiusFor(n);
      const lines = wrappedLabel(n);
      let widest = 0;
      for (const line of lines) {
        const w = measureCtx.measureText(line).width;
        if (w > widest) widest = w;
      }
      const horiz = widest / 2 + 8;             // half label width + margin
      const vert = (r + 6 + lines.length * 16) / 2 + 4; // mid of node+label box
      const value = Math.max(r + 4, horiz, vert);
      collideCache.set(n.id, value);
      return value;
    }

    // Canvas setup
    const canvas = document.createElement('canvas');
    canvas.style.width = '100%';
    canvas.style.height = '100%';
    canvas.style.display = 'block';
    canvas.style.touchAction = 'none';
    canvas.style.cursor = 'grab';
    host.appendChild(canvas);

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const dpr = window.devicePixelRatio || 1;

    const isLocal = mode === 'local';
    // Stop the simulation immediately on creation; we'll start it once
    // resize() has seeded positions around the actual canvas center.
    const sim = forceSimulation(nodes)
      .stop()
      .force('charge', forceManyBody().strength(isLocal ? -300 : -280))
      .force('link', forceLink(linkData).id((d: any) => d.id).distance(isLocal ? RADIAL_RADIUS : 145))
      // In local mode the rail viewport is small so we use a node-only
      // collide radius (with a small label buffer) — full label-aware
      // collide would force neighbors so far apart they wouldn't fit.
      .force('collide', forceCollide().radius(isLocal
        ? ((d: any) => radiusFor(d as GraphNode) + 6)
        : ((d: any) => collideRadius(d as GraphNode))
      ).strength(1).iterations(2))
      .alphaDecay(0.025)
      .velocityDecay(0.55);

    // Local mode: forceRadial actively pins neighbors at a fixed radius
    // around the center, producing the clean Obsidian-style ring. Charge
    // handles angular spread between siblings.
    // Global mode: use centering forces so the cluster sits in the canvas.
    let radialForce: ReturnType<typeof forceRadial> | null = null;
    if (isLocal) {
      radialForce = forceRadial(RADIAL_RADIUS, 0, 0).strength(0.85);
      sim.force('radial', radialForce);
    } else {
      sim
        .force('center', forceCenter(0, 0))
        .force('x', forceX(0).strength(0.07))
        .force('y', forceY(0).strength(0.07));
    }

    // Pan/zoom transform; identity until the user interacts.
    let transform = zoomIdentity;
    let dirty = true;
    let hovered: GraphNode | null = null;

    // Pointer / drag state
    type DownState = { pointerId: number; startX: number; startY: number; node: GraphNode | null; dragging: boolean };
    let down: DownState | null = null;
    const DRAG_THRESHOLD = 4;

    // True when the local widget is small (rail) — used to scale label
    // font size down so labels stay readable without devouring the small
    // canvas. Updated in resize() to react to rail-resize / modal-expand.
    let isSmallLocal = false;

    function resize() {
      const r = host.getBoundingClientRect();
      canvas.width = Math.max(1, Math.floor(r.width * dpr));
      canvas.height = Math.max(1, Math.floor(r.height * dpr));
      canvas.style.width = r.width + 'px';
      canvas.style.height = r.height + 'px';
      isSmallLocal = isLocal && r.width < 400;
      const cx = r.width / 2;
      const cy = r.height / 2;
      if (!isLocal) {
        sim.force('center', forceCenter(cx, cy));
      }
      if (radialForce) {
        radialForce.x(cx).y(cy);
      }
      if (centerNode) {
        centerNode.fx = cx;
        centerNode.fy = cy;
      }
      // First time we know the canvas dimensions, place the center node
      // and seed neighbors in an evenly-spaced ring around it. Without
      // this they'd start at default (0,0) and migrate as a cluster
      // toward canvas center, often settling lopsided.
      if (firstSeed && centerNode && r.width > 0 && r.height > 0) {
        centerNode.x = cx;
        centerNode.y = cy;
        const neighbors = nodes.filter((n) => n !== centerNode);
        const N = neighbors.length;
        if (N > 0) {
          const step = (2 * Math.PI) / N;
          const offset = -Math.PI / 2;
          neighbors.forEach((n, i) => {
            const a = offset + i * step;
            n.x = cx + RADIAL_RADIUS * Math.cos(a);
            n.y = cy + RADIAL_RADIUS * Math.sin(a);
            n.vx = 0;
            n.vy = 0;
          });
        }
        firstSeed = false;
        sim.alpha(1).restart();
      } else {
        sim.alpha(0.4).restart();
      }
      dirty = true;
    }

    function worldFromScreen(sx: number, sy: number): [number, number] {
      return [(sx - transform.x) / transform.k, (sy - transform.y) / transform.k];
    }

    function nodeAt(sx: number, sy: number): GraphNode | null {
      const [wx, wy] = worldFromScreen(sx, sy);
      // Hit radius stays roughly constant on-screen as we zoom.
      const hitR = 16 / transform.k;
      let best: GraphNode | null = null;
      let bestDist = hitR;
      for (const n of nodes) {
        const dx = (n.x ?? 0) - wx;
        const dy = (n.y ?? 0) - wy;
        const d = Math.hypot(dx, dy);
        if (d < bestDist) { bestDist = d; best = n; }
      }
      return best;
    }

    function draw() {
      const r = host.getBoundingClientRect();
      // Reset to a clean device-pixel transform, clear, then apply pan/zoom.
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx!.clearRect(0, 0, r.width, r.height);
      ctx!.translate(transform.x, transform.y);
      ctx!.scale(transform.k, transform.k);

      // Focused node = whatever the user is dragging, else what they're
      // hovering. When focused, the node + its direct neighbors stay full
      // color and the rest fade — Obsidian-style spotlight.
      const focused = down?.dragging ? down.node : hovered;
      let connected: Set<string> | null = null;
      if (focused) {
        connected = new Set<string>([focused.id]);
        for (const e of linkData) {
          const sId = (e.source as GraphNode).id;
          const tId = (e.target as GraphNode).id;
          if (sId === focused.id) connected.add(tId);
          if (tId === focused.id) connected.add(sId);
        }
      }

      // Labels fade with zoom: visible at default zoom, gone at extreme
      // zoom-out so they don't stack into an unreadable blob.
      const labelAlpha = Math.max(0, Math.min(1, (transform.k - 0.4) / 0.4));

      // Edges — thin and faint at rest, full opacity (accent) when an
      // endpoint is focused, near-invisible when not part of the focused
      // subset. Line width stays at ~1 screen px regardless of zoom.
      ctx!.lineWidth = 0.8 / transform.k;
      for (const e of linkData) {
        const sId = (e.source as GraphNode).id;
        const tId = (e.target as GraphNode).id;
        const isEdgeFocused = !!focused && (sId === focused.id || tId === focused.id);
        const isEdgeFaded = !!focused && !isEdgeFocused;
        ctx!.globalAlpha = isEdgeFocused ? 1 : isEdgeFaded ? 0.05 : 0.5;
        ctx!.strokeStyle = isEdgeFocused ? accent : edgeColor;
        ctx!.beginPath();
        ctx!.moveTo((e.source as GraphNode).x!, (e.source as GraphNode).y!);
        ctx!.lineTo((e.target as GraphNode).x!, (e.target as GraphNode).y!);
        ctx!.stroke();
      }
      ctx!.globalAlpha = 1;

      // Nodes + always-on labels (centered below each node). Focus does NOT
      // change the node's own color — only the edges to it light up. The
      // node just stays at full opacity while non-neighbors fade hard.
      for (const n of nodes) {
        const isCenter = n.id === centerSlug;
        const isInFocusSet = connected?.has(n.id) ?? false;
        const isFaded = !!focused && !isInFocusSet;

        const radius = radiusFor(n) + (isCenter ? 1.5 : 0);
        const nodeFill = isCenter ? accent : colorForGroup(n.group, accent, muted);

        ctx!.globalAlpha = isFaded ? 0.15 : 1;
        ctx!.beginPath();
        ctx!.arc(n.x!, n.y!, radius, 0, Math.PI * 2);
        ctx!.fillStyle = nodeFill;
        ctx!.fill();

        const lblAlpha = (isFaded ? 0.1 : 1) * labelAlpha;
        if (lblAlpha > 0.04) {
          // Scale text down in the small rail widget — Obsidian's local
          // graph uses a noticeably smaller font there to keep labels
          // legible without drowning the canvas.
          const fontPx = isSmallLocal ? 10 : 13;
          const linePx = isSmallLocal ? 12 : 16;
          ctx!.globalAlpha = lblAlpha;
          ctx!.font = '400 ' + (fontPx / transform.k) + 'px Inter, system-ui, sans-serif';
          // At rest, every label gets the bright `text` color — they should
          // be readable against the dark background without competing with
          // the edge lines. Only when there's an active focus does the
          // non-focused subset drop to `muted` (combined with the lower
          // alpha) to push the focused cluster forward.
          ctx!.fillStyle = !focused || isInFocusSet || isCenter ? text : muted;

          // Radial label placement: in local mode each non-center node's
          // label is anchored on the side of the node that points AWAY
          // from the center. Right of center → label to the right; top →
          // above; bottom → below; left → left. This keeps adjacent
          // neighbors' labels from stacking on the same band.
          const lines = wrappedLabel(n);
          const lineHeight = linePx / transform.k;
          const gap = 5 / transform.k;
          let labelX = n.x!;
          let labelY = n.y! + radius + gap;
          let align: CanvasTextAlign = 'center';
          if (isLocal && centerNode && n !== centerNode) {
            const cx = (centerNode.fx ?? centerNode.x ?? 0);
            const cy = (centerNode.fy ?? centerNode.y ?? 0);
            const dx = n.x! - cx;
            const dy = n.y! - cy;
            if (Math.abs(dx) > Math.abs(dy)) {
              // Horizontal axis dominates: label to the side, vertically
              // centered on the node.
              if (dx > 0) {
                labelX = n.x! + radius + gap;
                align = 'left';
              } else {
                labelX = n.x! - radius - gap;
                align = 'right';
              }
              labelY = n.y! - ((lines.length - 1) * lineHeight) / 2 - (fontPx / transform.k) / 2;
            } else if (dy < 0) {
              // Above the node: anchor block so its bottom sits just
              // above the node circle.
              labelY = n.y! - radius - gap - lines.length * lineHeight;
            }
            // Below (dy >= 0 in vertical-dominant case): default labelY.
          }
          ctx!.textAlign = align;
          ctx!.textBaseline = 'top';
          let y = labelY;
          for (const line of lines) {
            ctx!.fillText(line, labelX, y);
            y += lineHeight;
          }
        }
      }
      ctx!.globalAlpha = 1;
    }

    sim.on('tick', () => { dirty = true; });

    let alive = true;
    function frame() {
      if (!alive) return;
      if (dirty) { draw(); dirty = false; }
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    // d3-zoom for pan + zoom. Filter skips pan when pointerdown is on a node so
    // the manual node-drag handler below takes over.
    const zoomBehavior: ZoomBehavior<HTMLCanvasElement, unknown> = zoom<HTMLCanvasElement, unknown>()
      .scaleExtent([0.25, 4])
      .filter((event: any) => {
        if (event.type === 'wheel') return true;
        if (event.type === 'pointerdown' || event.type === 'mousedown' || event.type === 'touchstart') {
          const [sx, sy] = pointer(event, canvas);
          if (nodeAt(sx, sy)) return false;
        }
        return !event.ctrlKey && !event.button;
      })
      .on('start', () => { canvas.style.cursor = 'grabbing'; })
      .on('zoom', (event) => { transform = event.transform; dirty = true; })
      .on('end', () => { canvas.style.cursor = hovered ? 'pointer' : 'grab'; });
    select(canvas).call(zoomBehavior as any);

    // Manual node drag + click-vs-navigate logic.
    canvas.addEventListener('pointerdown', (ev) => {
      const r = canvas.getBoundingClientRect();
      const sx = ev.clientX - r.left;
      const sy = ev.clientY - r.top;
      const node = nodeAt(sx, sy);
      if (!node) return; // empty space — d3-zoom handles pan
      ev.preventDefault();
      try { canvas.setPointerCapture(ev.pointerId); } catch {}
      down = { pointerId: ev.pointerId, startX: sx, startY: sy, node, dragging: false };
      canvas.style.cursor = 'grabbing';
    });

    canvas.addEventListener('pointermove', (ev) => {
      const r = canvas.getBoundingClientRect();
      const sx = ev.clientX - r.left;
      const sy = ev.clientY - r.top;

      if (down && down.pointerId === ev.pointerId) {
        const dx = sx - down.startX;
        const dy = sy - down.startY;
        if (!down.dragging && Math.hypot(dx, dy) > DRAG_THRESHOLD) {
          down.dragging = true;
          // Low alphaTarget + extra friction = neighbors track the dragged
          // node smoothly without orbiting it. Reset on release.
          sim.alphaTarget(0.1).velocityDecay(0.65).restart();
        }
        if (down.dragging && down.node) {
          const [wx, wy] = worldFromScreen(sx, sy);
          down.node.fx = wx;
          down.node.fy = wy;
          dirty = true;
        }
        return;
      }

      // Hover handling (no pointer down)
      const node = nodeAt(sx, sy);
      if (node !== hovered) {
        hovered = node;
        canvas.style.cursor = node ? 'pointer' : 'grab';
        dirty = true;
      }
    });

    function endPointer(ev: PointerEvent, cancelled: boolean) {
      if (!down || down.pointerId !== ev.pointerId) return;
      const wasDrag = down.dragging;
      const node = down.node;
      try { canvas.releasePointerCapture(ev.pointerId); } catch {}
      if (wasDrag && node) {
        if (centerNode && node === centerNode) {
          // Re-pin the local graph's center node so it returns to canvas
          // center after the user lets go.
          const r = host.getBoundingClientRect();
          node.fx = r.width / 2;
          node.fy = r.height / 2;
        } else {
          node.fx = null;
          node.fy = null;
        }
        // Restore default damping; let the simulation settle to rest.
        sim.alphaTarget(0).velocityDecay(0.45);
      } else if (!cancelled && node) {
        // Click without drag → navigate.
        window.location.href = '/' + node.id;
      }
      down = null;
      canvas.style.cursor = hovered ? 'pointer' : 'grab';
      dirty = true;
    }

    canvas.addEventListener('pointerup', (ev) => endPointer(ev, false));
    canvas.addEventListener('pointercancel', (ev) => endPointer(ev, true));

    canvas.addEventListener('mouseleave', () => {
      hovered = null;
      dirty = true;
    });

    // Stop the rAF loop when the host is removed from the DOM (modal close,
    // view-transition swap of the rail).
    const stopObserver = new MutationObserver(() => {
      if (!host.isConnected) teardown();
    });
    stopObserver.observe(document.body, { childList: true, subtree: true });

    const ro = new ResizeObserver(resize);
    ro.observe(host);

    function teardown() {
      if (!alive) return;
      alive = false;
      sim.stop();
      stopObserver.disconnect();
      ro.disconnect();
    }

    // Expose hooks so external code (modal close handler) can re-fit the
    // canvas when layout state has shifted under us, or tear down the
    // simulation explicitly when removing the canvas without removing
    // the host (e.g. clearing the modal body on close).
    (host as any).__graphResize = resize;
    (host as any).__graphTeardown = teardown;

    resize();
  }

  function getCSSVar(name: string): string {
    return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
  }

  // Initialise any graph widgets currently in the DOM. Re-runs on every
  // view-transition page-load so newly-rendered rails get their graphs.
  function initGraphs() {
    document.querySelectorAll<HTMLElement>('.graph-widget[data-graph-mode]').forEach((host) => {
      if ((host as any).__graphInit) return;
      (host as any).__graphInit = true;
      const mode = (host.getAttribute('data-graph-mode') as 'local' | 'global') ?? 'local';
      const center = host.getAttribute('data-graph-center');
      renderGraph(host, mode, center);
    });
  }
  initGraphs();
  document.addEventListener('astro:page-load', initGraphs);

  // Modal: shared between expand-local and open-global.
  function openGraphModal(mode: 'local' | 'global', center: string | null) {
    let modal = document.querySelector('dialog.graph-modal') as HTMLDialogElement | null;
    if (!modal) {
      modal = document.createElement('dialog') as HTMLDialogElement;
      modal.className = 'graph-modal';
      modal.innerHTML = `
        <div class="graph-modal-toolbar">
          <button type="button" class="graph-tool" data-graph-modal-global aria-label="Switch to global graph" title="Open global graph">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><path d="M18 9v2c0 .6-.4 1-1 1H7c-.6 0-1-.4-1-1V9"/><path d="M12 12v3"/></svg>
          </button>
          <button type="button" class="graph-tool" data-graph-close aria-label="Close graph" title="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
        <div class="graph-modal-body"></div>
      `;
      document.body.appendChild(modal);
      modal.addEventListener('click', (e) => {
        const t = e.target as Element;
        if (!t || !t.closest) return;
        if (t.closest('[data-graph-close]')) { modal!.close(); return; }
        if (t.closest('[data-graph-modal-global]')) {
          // Swap the same modal to global mode.
          const body = modal!.querySelector('.graph-modal-body') as HTMLElement;
          modal!.setAttribute('data-graph-mode', 'global');
          renderGraph(body, 'global', null);
          return;
        }
        if (e.target === modal) modal!.close();
      });
      // When the dialog closes, (a) tear down the modal's simulation and
      // clear its canvas so it doesn't keep ticking invisibly, and (b)
      // refit any rail-side graph widget — the dialog's lifecycle can
      // leave the rail's canvas with stale dimensions and a blank render
      // until something prompts a redraw.
      modal.addEventListener('close', () => {
        const body = modal!.querySelector('.graph-modal-body') as HTMLElement | null;
        if (body) {
          (body as any).__graphTeardown?.();
          body.innerHTML = '';
        }
        document.querySelectorAll<HTMLElement>('.graph-widget[data-graph-mode]').forEach((widget) => {
          (widget as any).__graphResize?.();
        });
      });
    }
    const body = modal.querySelector('.graph-modal-body') as HTMLElement;
    body.innerHTML = '';
    body.style.height = '100%';
    modal.setAttribute('data-graph-mode', mode);
    if (typeof modal.showModal === 'function') modal.showModal();
    renderGraph(body, mode, center);
  }

  // Toolbar dispatch: expand opens local modal, global icon opens global modal.
  document.addEventListener('click', (ev) => {
    const target = ev.target as Element;
    if (!target || !target.closest) return;
    const expand = target.closest('[data-graph-expand]');
    const global = target.closest('[data-graph-global]');
    if (!expand && !global) return;
    ev.preventDefault();
    const widget = (expand ?? global)?.closest('.graph-widget') as HTMLElement | null;
    const center = expand ? widget?.getAttribute('data-graph-center') ?? null : null;
    openGraphModal(expand ? 'local' : 'global', center);
  });
</script>
